#!/usr/bin/env bash
set -euo pipefail

CURRENT_DIR="$(pwd -P)"
HOME_DIR="$(cd "$HOME" && pwd -P)"
PROJECT_NAME="$(basename "$CURRENT_DIR")"
GIT_NAME="${GIT_AUTHOR_NAME:-${GIT_COMMITTER_NAME:-$(git config --get user.name 2>/dev/null || true)}}"
GIT_EMAIL="${GIT_AUTHOR_EMAIL:-${GIT_COMMITTER_EMAIL:-$(git config --get user.email 2>/dev/null || true)}}"
ENV_FILE="$HOME/.config/picapsule/.env"

if [ "$CURRENT_DIR" = "/" ]; then
  echo "Erreur: impossible de lancer pi depuis /" >&2
  exit 1
fi

if [ "$CURRENT_DIR" = "$HOME_DIR" ]; then
  echo "Erreur: impossible de lancer pi depuis ~" >&2
  exit 1
fi

if [ ! -f "$ENV_FILE" ]; then
  echo "Création de $ENV_FILE..." >&2
  mkdir -p "$(dirname "$ENV_FILE")"
  touch "$ENV_FILE"
fi

# SSH agent forwarding setup
SSH_AUTH_SOCK_ARG=""
if [ -n "${SSH_AUTH_SOCK:-}" ]; then
  SSH_AUTH_SOCK_ARG="-v $SSH_AUTH_SOCK:/ssh-agent -e SSH_AUTH_SOCK=/ssh-agent"
fi

docker run -it --rm \
  --cap-drop=ALL \
  --security-opt no-new-privileges:true \
  --env-file "$HOME/.config/picapsule/.env" \
  -v "$CURRENT_DIR:/workspace/$PROJECT_NAME" \
  -v "$HOME/.pi:/home/piuser/.pi" \
  $SSH_AUTH_SOCK_ARG \
  -e "GIT_AUTHOR_NAME=$GIT_NAME" \
  -e "GIT_AUTHOR_EMAIL=$GIT_EMAIL" \
  -e "GIT_COMMITTER_NAME=$GIT_NAME" \
  -e "GIT_COMMITTER_EMAIL=$GIT_EMAIL" \
  -w /workspace/$PROJECT_NAME \
  picapsule "$@"
