#!/usr/bin/env bash
set -euo pipefail

CURRENT_DIR="$(pwd -P)"
HOME_DIR="$(cd "$HOME" && pwd -P)"
GIT_NAME="${GIT_AUTHOR_NAME:-${GIT_COMMITTER_NAME:-$(git config --get user.name 2>/dev/null || true)}}"
GIT_EMAIL="${GIT_AUTHOR_EMAIL:-${GIT_COMMITTER_EMAIL:-$(git config --get user.email 2>/dev/null || true)}}"

if [ "$CURRENT_DIR" = "/" ]; then
  echo "Erreur: impossible de lancer pi depuis /" >&2
  exit 1
fi

if [ "$CURRENT_DIR" = "$HOME_DIR" ]; then
  echo "Erreur: impossible de lancer pi depuis ~" >&2
  exit 1
fi

docker run -it --rm \
  --cap-drop=ALL \
  --security-opt no-new-privileges:true \
  --env-file "$HOME/.config/picapsule/.env" \
  -v "$CURRENT_DIR:/workspace" \
  -v "$HOME/.pi:/home/piuser/.pi" \
  -e "GIT_AUTHOR_NAME=$GIT_NAME" \
  -e "GIT_AUTHOR_EMAIL=$GIT_EMAIL" \
  -e "GIT_COMMITTER_NAME=$GIT_NAME" \
  -e "GIT_COMMITTER_EMAIL=$GIT_EMAIL" \
  -w /workspace \
  picapsule "$@"
